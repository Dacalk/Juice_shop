{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "backend/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/dist/$1"
    }
  ],
  "cleanUrls": true
}
